{
  "name": "@decision3/interouter-core",
  "version": "0.1.3",
  "description": "Core middleware that aggregates on-chain state and AI inference into a single optimized JSON for Next.js frontends.",
  "license": "MIT",
  "author": "Decision3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/decision3-ai/interouter.git"
  },
  "homepage": "https://decision3.ai",
  "bugs": {
    "url": "https://github.com/decision3-ai/interouter/issues"
  },
  "keywords": [
    "x402",
    "ai-agents",
    "ai-inference",
    "middleware",
    "blockchain",
    "near",
    "evm",
    "openledger",
    "payment",
    "decentralized",
    "facilitator",
    "web3"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "tsx --test src/router.test.ts src/adapters/NearAdapter.test.ts src/adapters/OpenLedgerAdapter.test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "near-api-js": "^7.2.0",
    "viem": "^2.49.3"
  },
  "devDependencies": {
    "tsx": "^4.22.1",
    "typescript": "^5.4.0"
  }
}
